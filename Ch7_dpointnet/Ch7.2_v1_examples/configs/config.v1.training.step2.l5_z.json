{
  "manifest": {
    "$BASE_DIR": ".",
    "$OUTPUT_DIR": "$BASE_DIR/output_training_step2_l5_z",
    "$NETWORK_DIR": "$BASE_DIR/GLIF_network/network",
    "$TRAINED_NETWORK_DIR": "$BASE_DIR/training_callbacks_step1_fr/network.trained_weights.best",
    "$MODELS_DIR": "$BASE_DIR/GLIF_network/components"
  },
  "target_simulator": "RNN",
  "run": {
    "seq_len": 500,
    "dt": 1.0,
    "batch_size": 1,
    "t_start": 0.0,
    "default_seed": 3100,
    "train_recurrent_weights": true,
    "dtype": "float16",
    "checkpoint": {}
  },
  "rnn_cell_params": {
    "cell_model": "GLIF3Cell",
    "gauss_std": 0.3,
    "dampening_factor": 0.1,
    "recurrent_dampening_factor": 0.1,
    "voltage_gradient_dampening": 0.5,
    "recurrent_weight_scale": 1.0,
    "pseudo_gauss": false,
    "lr_scale": 1.0,
    "max_delay": 0,
    "hard_reset": false,
    "tau_basis": "$MODELS_DIR/synaptic_data/tau_basis.npy",
    "basis_weights_file": "$MODELS_DIR/synaptic_data/basis_function_weights.csv"
  },
  "inputs": {
    "lgn_dg0": {
      "node_set": "lgn",
      "trainable": false,
      "input": "spikes",
      "module": "lgn_tf",
      "stimulus_type": "drifting_gratings",
      "stimulus_options": {
        "orientation": 0.0,
        "temporal_f": 2.0,
        "row_size": 80,
        "col_size": 120,
        "pre_delay": 0,
        "post_delay": 0,
        "phase": 0.0
      }
    },
    "lgn_dg180": {
      "node_set": "lgn",
      "trainable": false,
      "input": "spikes",
      "module": "lgn_tf",
      "stimulus_type": "drifting_gratings",
      "stimulus_options": {
        "orientation": 180.0,
        "temporal_f": 2.0,
        "row_size": 80,
        "col_size": 120,
        "pre_delay": 0,
        "post_delay": 0,
        "phase": 0.0
      }
    },
    "bkg_random": {
      "node_set": "bkg",
      "trainable": true,
      "input": "spikes",
      "module": "poisson_spikes_internal",
      "firing_rate": 250.0
    }
  },
  "initial_states": {
    "zero_init_state": {
      "module": "zero_state"
    }
  },
  "training": {
    "n_epochs": 10,
    "steps_per_epoch": 10,
    "batch_size": 1,
    "training_approach": "parallel",
    "learning_rate": {
      "schedule": "none",
      "learning_rate": 0.03
    },
    "optimizer": {
      "name": "exp_adam",
      "epsilon": 1e-11
    },
    "initial_state": {
      "module": "zero_state"
    },
    "callbacks": {
      "class": "Callbacks",
      "starting_epoch": 0,
      "callbacks_dir": "training_callbacks_step2_l5_z",
      "verbose": "on_step",
      "epoch_store_weights": "latest",
      "epoch_cache_weights": false,
      "sonata_output_dir": "network.trained_weights.best",
      "losses_table_csv": "losses.csv",
      "performance_table_csv": "performance.csv"
    },
    "parameters": [
      {
        "name": "dg0",
        "inputs": [
          "lgn_dg0",
          "bkg_random"
        ],
        "loss_functions": {
          "dg0_l5_left_right": {
            "module": "L5ZAxisBiasLoss",
            "cost": 2.0,
            "dgsign": 1.0,
            "data_dir": "./GLIF_network",
            "layer": "L5",
            "z_scale": 400.0
          },
          "dg0_rate_regularizer": {
            "module": "SpikeRateDistributionTarget",
            "rate_cost": 10000.0,
            "pre_delay": 0.0,
            "post_delay": 0.0,
            "core_radius": 400.0,
            "annulus_loss_weight": 0.0,
            "stimulus_type": "drifting_gratings",
            "neuropixels_df": "$BASE_DIR/Neuropixels_data/OSI_DSI_neuropixels_v4.csv.gz"
          },
          "dg0_voltage_regularizer": {
            "module": "VoltageRegularization",
            "voltage_cost": 1.0,
            "penalty_mode": "threshold"
          },
          "dg0_weight_regularizer": {
            "module": "EMDWeightRegularization",
            "cost": 10.0,
            "data_dir": "./GLIF_network"
          }
        }
      },
      {
        "name": "dg180",
        "inputs": [
          "lgn_dg180",
          "bkg_random"
        ],
        "loss_functions": {
          "dg180_l5_left_right": {
            "module": "L5ZAxisBiasLoss",
            "cost": 2.0,
            "dgsign": -1.0,
            "data_dir": "./GLIF_network",
            "layer": "L5",
            "z_scale": 400.0
          },
          "dg180_rate_regularizer": {
            "module": "SpikeRateDistributionTarget",
            "rate_cost": 10000.0,
            "pre_delay": 0.0,
            "post_delay": 0.0,
            "core_radius": 400.0,
            "annulus_loss_weight": 0.0,
            "stimulus_type": "drifting_gratings",
            "neuropixels_df": "$BASE_DIR/Neuropixels_data/OSI_DSI_neuropixels_v4.csv.gz"
          },
          "dg180_voltage_regularizer": {
            "module": "VoltageRegularization",
            "voltage_cost": 1.0,
            "penalty_mode": "threshold"
          },
          "dg180_weight_regularizer": {
            "module": "EMDWeightRegularization",
            "cost": 10.0,
            "data_dir": "./GLIF_network"
          }
        }
      }
    ]
  },
  "inference": {
    "initial_state": {
      "module": "zero_state"
    },
    "output": {
      "overwrite_results": true
    },
    "parameters": [
      {
        "name": "dg0",
        "inputs": [
          "lgn_dg0",
          "bkg_random"
        ],
        "output": {
          "output_dir": "output_inference_step2_dg0",
          "spikes_file": "spikes_dg0.h5"
        }
      },
      {
        "name": "dg180",
        "inputs": [
          "lgn_dg180",
          "bkg_random"
        ],
        "output": {
          "output_dir": "output_inference_step2_dg180",
          "spikes_file": "spikes_dg180.h5"
        }
      }
    ],
    "batch_size": 1,
    "seq_len": 500
  },
  "output": {
    "output_dir": "$OUTPUT_DIR",
    "log_file": "log.txt",
    "log_level": "INFO",
    "spikes_file": "spikes_ori${matrix:angle}_${bmtk:batch_num}.h5",
    "voltages_file": "voltages_ori${matrix:angle}_${bmtk:batch_num}.h5"
  },
  "components": {
    "point_neuron_models_dir": "$MODELS_DIR/cell_models",
    "synaptic_models_dir": "$MODELS_DIR/synaptic_models"
  },
  "networks": {
    "nodes": [
      {
        "nodes_file": "$NETWORK_DIR/v1_nodes.h5",
        "node_types_file": "$NETWORK_DIR/v1_node_types.csv"
      },
      {
        "nodes_file": "$NETWORK_DIR/lgn_nodes.h5",
        "node_types_file": "$NETWORK_DIR/lgn_node_types.csv"
      },
      {
        "nodes_file": "$NETWORK_DIR/bkg_nodes.h5",
        "node_types_file": "$NETWORK_DIR/bkg_node_types.csv"
      }
    ],
    "edges": [
      {
        "edges_file": "$TRAINED_NETWORK_DIR/v1_v1_edges.h5",
        "edge_types_file": "$NETWORK_DIR/v1_v1_edge_types.csv"
      },
      {
        "edges_file": "$TRAINED_NETWORK_DIR/lgn_v1_edges.h5",
        "edge_types_file": "$NETWORK_DIR/lgn_v1_edge_types.csv"
      },
      {
        "edges_file": "$TRAINED_NETWORK_DIR/bkg_v1_edges.h5",
        "edge_types_file": "$NETWORK_DIR/bkg_v1_edge_types.csv"
      }
    ]
  }
}
